{
  "name": "tahoe200-2026",
  "type": "module",
  "version": "1.0.0",
  "description": "Harvey's Tahoe 200 2026 — crew, pacers, family follow-along.",
  "scripts": {
    "prebuild": "node scripts/copy-ui.mjs && node scripts/copy-data.mjs",
    "dev": "node scripts/copy-ui.mjs && node scripts/copy-data.mjs && astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "art:nga": "node scripts/build-nga-art-pairings.mjs",
    "ui:copy": "node scripts/copy-ui.mjs",
    "agent:demo": "bash scripts/agent-demo.sh",
    "agent:sim": "python3 scripts/simulate_race.py",
    "agent:restore": "python3 scripts/restore_real_status.py",
    "agent:verify": "bash scripts/verify-agent.sh \"${PUBLIC_AGENT_API_URL:-https://views-spirit-words-built.trycloudflare.com}\"",
    "agent:preflight": "bash scripts/laptop-preflight.sh"
  },
  "dependencies": {
    "astro": "^5.7.10"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
