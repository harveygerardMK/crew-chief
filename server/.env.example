# Anthropic (required for /chat)
ANTHROPIC_API_KEY=

# Claude settings
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_MAX_TOKENS=1000

# Data paths (defaults assume repo root layout on droplet)
# HARVEY_STATUS_PATH=/var/crew-chief/data/harvey_status.json
# VISITORS_PATH=/var/crew-chief/data/visitors.json
# VOICE_PATH=/var/crew-chief/voice.md
# ART_PAIRINGS_PATH=/var/crew-chief/data/art-pairings.json
# AID_STATIONS_PATH=/var/crew-chief/data/aid-stations.json
# QUESTIONS_PATH=/var/crew-chief/data/questions.json
# NOTES_PATH=/var/crew-chief/data/notes.json

# CORS — comma-separated origins, or * for open (v1 default)
# CORS_ORIGINS=*

# Optional: Langfuse tracing for /chat accuracy audits (see docs/superpowers/runbooks/crew-chief-agent-langfuse.md)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# US region: https://us.cloud.langfuse.com

# Optional: backup visitors.json to GitHub on each write
# GITHUB_TOKEN=
# GITHUB_OWNER=harveygerardMK
# GITHUB_REPO=crew-chief
# GITHUB_BRANCH=main
# VISITORS_EXPORT_PATH=data/visitors.json
