# TrackLeaders event slug (set when the Tahoe 200 map goes live).
# TRACKLEADERS_EVENT_SLUG=tahoe20026

# Runner name exactly as shown on the TrackLeaders sidebar.
# TRACKLEADERS_RUNNER_NAME=Harvey Schaefer

# Optional full TrackLeaders runner page URL if slug/name are not yet known.
# TRACKLEADERS_FALLBACK_URL=https://trackleaders.com/tahoe20026i.php?name=Harvey_Schaefer

# Optional override for output path (default: ../data/harvey_status.json)
# HARVEY_STATUS_PATH=/var/crew-chief/data/harvey_status.json
