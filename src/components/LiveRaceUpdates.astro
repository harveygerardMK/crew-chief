---
import { raceBroadcastUpdates } from "../lib/data";
import { hasBroadcastUpdates } from "../lib/broadcast";

/** Newest first (sorted in data layer); highest Update # at the top. */
const updates = hasBroadcastUpdates(raceBroadcastUpdates) ? raceBroadcastUpdates : [];

function formatUpdatedAt(iso: string): string {
  return new Date(iso).toLocaleString("en-US", {
    timeZone: "America/Los_Angeles",
    weekday: "short",
    month: "short",
    day: "numeric",
    hour: "numeric",
    minute: "2-digit",
    timeZoneName: "short",
  });
}
---

<section class="live-updates" aria-labelledby="live-updates-heading">
  <header class="live-updates__header card-surface__header">
    <p class="card-surface__eyebrow">Family feed</p>
    <h2 id="live-updates-heading" class="live-updates__title card-surface__title">
      Live Race Updates from Harvey's Cuter Half
    </h2>
    {
      updates.length > 0 && updates[0]?.updated_at && (
        <p class="live-updates__meta card-surface__meta">
          Latest {formatUpdatedAt(updates[0].updated_at)}
          {updates.length > 1 && ` · ${updates.length} updates`}
        </p>
      )
    }
  </header>

  {
    updates.length > 0 ? (
      <div class="live-updates__list">
        {
          updates.map((entry, index) => {
            const number = updates.length - index;
            const openDefault = index === 0;
            const doing = entry.doing?.trim();
            const station = entry.last_seen?.station?.trim();
            const timeLabel = entry.last_seen?.time_label?.trim();
            const note = entry.note?.trim();

            return (
              <details class="live-update-item" open={openDefault}>
                <summary class="live-update-item__summary">
                  <span class="live-update-item__title">Update #{number}</span>
                  {entry.updated_at && (
                    <span class="live-update-item__when">
                      {formatUpdatedAt(entry.updated_at)}
                    </span>
                  )}
                </summary>

                <div class="live-update-item__panel">
                  {
                    doing && (
                      <div class="live-update-field">
                        <p class="live-update-field__label">How's Harvey doing?</p>
                        <div class="live-update-field__value">{doing}</div>
                      </div>
                    )
                  }

                  {
                    station && (
                      <div class="live-update-field">
                        <p class="live-update-field__label">Last seen aid station</p>
                        <div class="live-update-field__value">{station}</div>
                      </div>
                    )
                  }

                  {
                    timeLabel && (
                      <div class="live-update-field">
                        <p class="live-update-field__label">Time last seen</p>
                        <div class="live-update-field__value">{timeLabel}</div>
                      </div>
                    )
                  }

                  {
                    note && (
                      <div class="live-update-field">
                        <p class="live-update-field__label">Note for family (optional)</p>
                        <div class="live-update-field__value live-update-field__value--note">
                          {note}
                        </div>
                      </div>
                    )
                  }

                  {
                    entry.photos.length > 0 && (
                      <div class="live-update-field">
                        <p class="live-update-field__label">Photos</p>
                        <div
                          class="live-updates__photos"
                          role="group"
                          aria-label="Photos from crew"
                        >
                          {
                            entry.photos.map((photo) => (
                              <a
                                class="live-updates__photo-link"
                                href={photo.url}
                                target="_blank"
                                rel="noopener noreferrer"
                              >
                                <img
                                  src={photo.url}
                                  alt={photo.alt}
                                  loading="lazy"
                                  width="160"
                                  height="160"
                                />
                              </a>
                            ))
                          }
                        </div>
                      </div>
                    )
                  }
                </div>
              </details>
            );
          })
        }
      </div>
    ) : (
      <p class="live-updates__empty">
        Updates will show up here during race weekend when Karen posts from the trail.
        Check back after the start on Friday morning.
      </p>
    )
  }
</section>
