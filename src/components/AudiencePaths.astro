---
const base = import.meta.env.BASE_URL;

const paths = [
  {
    href: `${base}next/`,
    title: "Next stop",
    desc: "Harvey's next crew meet — leave-by & Maps",
    className: "audience-path--plan",
  },
  {
    href: `${base}crew/`,
    title: "Crew & playbooks",
    desc: "7 Tahoe aids · checklists · parking",
    className: "audience-path--crew",
  },
  {
    href: `${base}board/`,
    title: "Race board",
    desc: "Harvey's plan vs actual at every aid",
    className: "audience-path--board",
  },
  {
    href: `${base}follow/`,
    title: "See Harvey",
    desc: "Family view · ETAs · live tracker",
    className: "audience-path--follow",
  },
];
---

<section class="audience-paths" aria-labelledby="paths-heading">
  <h2 id="paths-heading">Where do you need to go?</h2>
  <div class="audience-paths__grid">
    {
      paths.map((p) => (
        <a href={p.href} class:list={["audience-path", p.className]}>
          <span class="audience-path__title">{p.title}</span>
          <span class="audience-path__desc">{p.desc}</span>
          <span class="audience-path__arrow" aria-hidden="true">→</span>
        </a>
      ))
    }
  </div>
</section>
