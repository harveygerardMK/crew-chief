---
const base = import.meta.env.BASE_URL;

const sections = [
  {
    title: "Crew",
    desc: "Race week — where to meet me",
    paths: [
      {
        href: `${base}next/`,
        title: "Next stop",
        desc: "Leave-by time · Maps · check in",
        className: "audience-path--plan",
      },
      {
        href: `${base}board/`,
        title: "Race board",
        desc: "Plan vs when I actually showed up",
        className: "audience-path--board",
      },
      {
        href: `${base}crew/`,
        title: "Crew guide",
        desc: "Playbooks · parking · timeline",
        className: "audience-path--crew",
      },
      {
        href: `${base}aid-stations/`,
        title: "Aid stations",
        desc: "All 13 stops · cutoffs",
        className: "audience-path--aid",
      },
    ],
  },
  {
    title: "Plan",
    desc: "Course, kit, race week",
    paths: [
      {
        href: `${base}course/`,
        title: "Course",
        desc: "200.4 mi · map · segments",
        className: "audience-path--course",
      },
      {
        href: `${base}gear/`,
        title: "Gear",
        desc: "Mandatory list · drop bags",
        className: "audience-path--gear",
      },
      {
        href: `${base}schedule/`,
        title: "Schedule",
        desc: "June 11–17",
        className: "audience-path--schedule",
      },
    ],
  },
  {
    title: "Pacers",
    desc: "Loon Lake to the finish",
    paths: [
      {
        href: `${base}pacers/`,
        title: "Pacers",
        desc: "Legs · gear · rules",
        className: "audience-path--pacers",
      },
    ],
  },
];

const followLink = `${base}follow/`;
---

<section class="audience-paths" aria-labelledby="paths-heading">
  <h2 id="paths-heading">Start here</h2>
  {
    sections.map((section) => (
      <div class="audience-paths__section">
        <div class="audience-paths__section-head">
          <h3>{section.title}</h3>
          <p>{section.desc}</p>
        </div>
        <div class="audience-paths__grid">
          {section.paths.map((p) => (
            <a href={p.href} class:list={["audience-path", p.className]}>
              <span class="audience-path__title">{p.title}</span>
              <span class="audience-path__desc">{p.desc}</span>
              <span class="audience-path__arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    ))
  }
  <p class="card__meta audience-paths__follow">
    Family & friends: <a href={followLink}>Follow along</a> — spectator stops and the tracker
  </p>
</section>
