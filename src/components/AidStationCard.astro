---
import type { AidStation } from "../lib/data";
import { findCrewStopForAid, mapsUrl } from "../lib/station-links";

interface Props {
  station: AidStation;
}

const { station } = Astro.props;
const isSleep = station.type === "Sleep";
const crewStop = station.crew_access ? findCrewStopForAid(station.name, station.n) : null;
const base = import.meta.env.BASE_URL;
const mapsLink = mapsUrl(station.coordinates.lat, station.coordinates.lng);

const eyebrowParts = [
  `Mile ${station.mile}`,
  station.type,
  station.crew_access && "Crew",
  station.pacer_access && "Pacer",
  isSleep && "Sleep",
  station.drop_bag && "Drop bag",
].filter(Boolean);
---

<article
  id={`aid-${station.n}`}
  class="aid-card"
  data-aid-card
  data-crew={station.crew_access}
  data-pacer={station.pacer_access}
  data-sleep={isSleep}
>
  <p class="aid-card__eyebrow">{eyebrowParts.join(" · ")}</p>
  <h3 class="aid-card__title">{station.name}</h3>
  <p class="aid-card__cutoff">Cutoff {station.cutoff}</p>
  {station.notes && <p class="aid-card__notes">{station.notes}</p>}
  <div class="aid-card__links">
    {
      crewStop && (
        <a href={`${base}crew/#stop-${crewStop.n}`}>Crew stop →</a>
      )
    }
    <a href={mapsLink} target="_blank" rel="noopener noreferrer">Directions →</a>
  </div>
</article>
