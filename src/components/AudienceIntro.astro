---
interface Props {
  audience: "crew" | "pacers" | "follow" | "runner";
}

const { audience } = Astro.props;

const copy = {
  crew: {
    title: "For Harvey's crew",
    body: "Where to meet Harvey at crew-access aids — parking, ETAs, playbooks, and cutoffs for Tahoe 200.",
  },
  pacers: {
    title: "For Harvey's pacers",
    body: "Six legs from Loon Lake to the finish, mandatory kit, and rules that affect Harvey if you slip up.",
  },
  follow: {
    title: "For family & friends",
    body: "Follow Harvey at the Tahoe 200 — when to expect him at spectator stops, tracker tips, and reassurance.",
  },
  runner: {
    title: "For Harvey",
    body: "Your Tahoe 200 plan — course, gear, schedule, and status in one place.",
  },
} as const;

const c = copy[audience];
---

<aside class="audience-intro" aria-label={`This page is ${c.title.toLowerCase()}`}>
  <p class="audience-intro__label">{c.title}</p>
  <p class="audience-intro__body">{c.body}</p>
</aside>
