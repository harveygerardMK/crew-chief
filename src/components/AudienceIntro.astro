---
interface Props {
  audience: "crew" | "pacers" | "follow" | "runner";
}

const { audience } = Astro.props;

const copy = {
  crew: {
    title: "For crew",
    body: "Where to meet me at crew aids — parking, ETAs, playbooks, cutoffs.",
  },
  pacers: {
    title: "For pacers",
    body: "Four legs from Loon Lake to the finish, mandatory kit, and rules that DQ me if we get them wrong.",
  },
  follow: {
    title: "For family & friends",
    body: "Where you can actually see me, rough ETAs, and how to read the tracker without panicking.",
  },
  runner: {
    title: "My plan",
    body: "Course, gear, schedule, and status — Tahoe 200 only.",
  },
} as const;

const c = copy[audience];
---

<aside class="audience-intro" aria-label={c.title}>
  <p class="audience-intro__label">{c.title}</p>
  <p class="audience-intro__body">{c.body}</p>
</aside>
