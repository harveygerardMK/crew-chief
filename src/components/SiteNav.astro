---
import { primaryNav, isPrimaryNavActive, hrefWithBase } from "../lib/nav";

interface Props {
  canonicalPath: string;
  base: string;
}

const { canonicalPath, base } = Astro.props;
---

<nav class="site-nav" aria-label="Main">
  {
    primaryNav.map((item, index) => (
      <>
        {index > 0 && <span class="site-nav__rule" aria-hidden="true" />}
        <a
          href={hrefWithBase(base, item.href)}
          class="site-nav__link"
          aria-current={isPrimaryNavActive(canonicalPath, item) ? "page" : undefined}
        >
          {item.label}
        </a>
      </>
    ))
  }
</nav>
