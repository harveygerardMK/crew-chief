---
import { race, status } from "../lib/data";
import { getCountdown, getRacePhase } from "../lib/dates";
import WheresHarvey from "./WheresHarvey.astro";

const phase = status.phase === "pre-race" && getRacePhase() === "on-course" ? "on-course" : status.phase;
const countdown = phase === "pre-race" ? getCountdown() : null;
---

{
  phase === "pre-race" ? (
    <section
      class:list={["status-block", "card-surface", "status-block--pre-race"]}
      aria-live="polite"
      aria-labelledby="status-primary"
    >
      <header class="card-surface__header">
        <p class="card-surface__eyebrow">Race status</p>
      </header>
      <p id="status-primary" class="status-block__primary card-surface__title">
        {(countdown ?? "Race week").toUpperCase()}
      </p>
      <p class="status-block__detail card-surface__meta">June 12 · 9:00 AM PDT</p>
      <p class="status-block__detail card-surface__meta">{race.start.location}</p>
      {status.message && <p class="status-block__secondary">{status.message}</p>}
    </section>
  ) : phase === "on-course" ? (
    <WheresHarvey />
  ) : (
    <section
      class:list={["status-block", "card-surface", "status-block--finished"]}
      aria-live="polite"
      aria-labelledby="status-primary"
    >
      <header class="card-surface__header">
        <p class="card-surface__eyebrow">Race status</p>
      </header>
      <p id="status-primary" class="status-block__primary card-surface__title">RACE COMPLETE</p>
      {status.message && <p class="status-block__secondary">{status.message}</p>}
    </section>
  )
}
