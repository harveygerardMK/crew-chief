---
import { race, raceBroadcast, status } from "../lib/data";
import { hasBroadcast } from "../lib/broadcast";
import { getCountdown, getRacePhase } from "../lib/dates";
import {
  formatPlanTimeShort,
  getNextPlannedCrewStop,
  plannedArrivalDate,
} from "../lib/tahoe-plan";
import BroadcastStrip from "./BroadcastStrip.astro";

const base = import.meta.env.BASE_URL;
const phase = status.phase === "pre-race" && getRacePhase() === "on-course" ? "on-course" : status.phase;
const countdown = phase === "pre-race" ? getCountdown() : null;
const nextCrew = phase === "on-course" ? getNextPlannedCrewStop(status.last_seen_station) : null;
const nextEta =
  nextCrew ? formatPlanTimeShort(plannedArrivalDate(nextCrew.mile, "baseline")) : null;

const broadcast = hasBroadcast(raceBroadcast) ? raceBroadcast : null;
const lastSeenStation =
  broadcast?.last_seen?.station?.trim() || status.last_seen_station || null;
const lastSeenTime =
  broadcast?.last_seen?.time_label?.trim() || status.last_seen_time || null;
const doingLine = broadcast?.doing?.trim() || null;
const statusMessage =
  phase === "on-course" && doingLine ? doingLine : status.message;
---

<section
  class:list={["status-block", `status-block--${phase}`]}
  aria-live="polite"
  aria-labelledby="status-primary"
>
  {
    phase === "pre-race" ? (
      <>
        <p id="status-primary" class="status-block__primary">
          {(countdown ?? "Race week").toUpperCase()}
        </p>
        <p class="status-block__detail">June 12 · 9:00 AM PDT</p>
        <p class="status-block__detail">{race.start.location}</p>
        {status.message && <p class="status-block__secondary">{status.message}</p>}
        {broadcast && <BroadcastStrip broadcast={broadcast} />}
      </>
    ) : phase === "on-course" ? (
      <>
        <p id="status-primary" class="status-block__primary">
          <span class="status-block__pulse" aria-hidden="true" />
          ON COURSE
        </p>
        <p class="status-block__detail">
          {lastSeenStation ? `Last seen: ${lastSeenStation}` : "Harvey is on course"}
        </p>
        {lastSeenTime && <p class="status-block__detail">{lastSeenTime}</p>}
        {
          nextCrew && nextEta && (
            <p class="status-block__detail">
              Next crew: {nextCrew.name} (mile {nextCrew.mile}) · plan ~{nextEta}
            </p>
          )
        }
        {statusMessage && <p class="status-block__secondary">{statusMessage}</p>}
        <p class="status-block__actions">
          <a class="btn btn--secondary" href={`${base}next/`}>Next stop →</a>
          <a class="btn btn--secondary" href={`${base}board/`}>View board →</a>
        </p>
        {broadcast && <BroadcastStrip broadcast={broadcast} />}
      </>
    ) : (
      <>
        <p id="status-primary" class="status-block__primary">RACE COMPLETE</p>
        {status.message && <p class="status-block__secondary">{status.message}</p>}
        {broadcast && <BroadcastStrip broadcast={broadcast} />}
      </>
    )
  }
</section>
