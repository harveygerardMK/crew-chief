---
import type { PacerLeg } from "../lib/data";

interface Props {
  leg: PacerLeg;
}

const { leg } = Astro.props;
---

<article class="pacer-leg-card">
  <p class="pacer-leg-card__eyebrow">Leg {leg.leg}</p>
  <h3 class="pacer-leg-card__title">
    {leg.from} → {leg.to}
  </h3>
  <div class="pacer-leg-card__stats tabular" role="group" aria-label="Leg stats">
    <span><strong>{leg.miles}</strong> mi</span>
    <span><strong>{leg.gain_ft.toLocaleString()}</strong> ft gain</span>
    <span>{leg.estimated_time_of_day}</span>
  </div>
  <hr class="pacer-leg-card__rule" />
  <p class="pacer-leg-card__notes">{leg.terrain_notes}</p>
  <h4 class="pacer-leg-card__bring-label">What to bring</h4>
  <ul class="pacer-leg-card__list">
    {leg.what_to_bring.map((item) => <li>{item}</li>)}
  </ul>
</article>
