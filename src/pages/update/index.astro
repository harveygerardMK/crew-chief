---
/** Amanda posts at the broadcast Worker — one form, same-origin saves (no CORS). */
const workerBase =
  (import.meta.env.PUBLIC_BROADCAST_API_URL ?? "").replace(/\/$/, "") ||
  "https://crew-chief-broadcast.harvey-schaefer.workers.dev";
const updateUrl = `${workerBase}/update`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0;url=${updateUrl}`} />
    <link rel="canonical" href={updateUrl} />
    <title>Crew update · Tahoe 200</title>
    <style>
      body {
        font-family: system-ui, sans-serif;
        max-width: 28rem;
        margin: 2rem auto;
        padding: 0 1rem;
        line-height: 1.5;
        color: #1b2a2e;
        background: #f2ede3;
      }
      a {
        color: #b5451f;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <p>Opening the crew update form…</p>
    <p>
      <a href={updateUrl}>Tap here if you are not redirected</a>
    </p>
  </body>
</html>
