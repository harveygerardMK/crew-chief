---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { aidStations } from "../../lib/data";

const apiUrl = import.meta.env.PUBLIC_BROADCAST_API_URL ?? "";
const stationNames = aidStations.map((s) => s.name);
---

<BaseLayout
  title="Crew update"
  description="Post a race update for the homepage."
  noindex
>
  <div id="update-app" class="container update-page" data-api-url={apiUrl}>
    <h1>Crew update</h1>
    <p class="lead">Short note for family on the homepage. Takes a few minutes to show up after you save.</p>

    <p id="status" class="update-status" role="status" aria-live="polite" hidden></p>

    <section id="login" class="update-panel">
      <h2>Sign in</h2>
      <label class="update-field">
        <span class="update-field__label">Family password</span>
        <input id="password" type="password" autocomplete="current-password" class="update-input" />
      </label>
      <button id="login-btn" type="button" class="btn btn--primary">Continue</button>
    </section>

    <section id="form" class="update-panel" hidden>
      <h2>Update for family</h2>

      <label class="update-field">
        <span class="update-field__label">How's Harvey doing?</span>
        <textarea id="doing" rows="2" maxlength="200" class="update-input" placeholder="e.g. Tired but moving — just left Sierra"></textarea>
      </label>

      <label class="update-field">
        <span class="update-field__label">Last seen aid station</span>
        <select id="station" class="update-input">
          <option value="">— Skip if you're only posting a quick line —</option>
          {stationNames.map((name) => <option value={name}>{name}</option>)}
          <option value="__other__">Other…</option>
        </select>
      </label>

      <label class="update-field">
        <span class="update-field__label">Other station name</span>
        <input id="station_other" type="text" class="update-input" hidden maxlength="80" />
      </label>

      <label class="update-field">
        <span class="update-field__label">Time last seen</span>
        <input id="time_seen" type="datetime-local" class="update-input" />
      </label>

      <label class="update-field">
        <span class="update-field__label">Note for family (optional)</span>
        <textarea id="note" rows="4" maxlength="500" class="update-input" placeholder="Sleeping at Wrights — see you at Tahoe City Monday AM"></textarea>
      </label>

      <label class="update-field">
        <span class="update-field__label">Photo 1 (optional)</span>
        <input name="photo0" type="file" accept="image/jpeg,image/png,image/webp" class="update-input" />
      </label>

      <label class="update-field">
        <span class="update-field__label">Photo 2 (optional)</span>
        <input name="photo1" type="file" accept="image/jpeg,image/png,image/webp" class="update-input" />
      </label>

      <button id="save-btn" type="button" class="btn btn--primary">Save update</button>
    </section>
  </div>

  <script>
    import { initBroadcastAdmin } from "../../scripts/broadcast-admin.ts";
    const root = document.getElementById("update-app");
    initBroadcastAdmin(root?.dataset.apiUrl ?? "");
  </script>
</BaseLayout>
