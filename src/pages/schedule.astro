---
import BaseLayout from "../layouts/BaseLayout.astro";
import AudienceIntro from "../components/AudienceIntro.astro";
import { raceWeek } from "../lib/data";
---

<BaseLayout title="Schedule" description="Race calendar — check-in through bag pickup, June 11–17, 2026.">
  <div class="container">
    <AudienceIntro audience="runner" />
    <h1>Race schedule</h1>
    <p class="lead">June 11–17, 2026 — check-in, the run, cutoff, and drop-bag pickup</p>

    {
      raceWeek.map((day) => {
        const highlight =
          day.activity.includes("RACE") ||
          day.activity.includes("CHECK-IN") ||
          day.activity.includes("FINISH") ||
          day.activity.includes("Drop bag");
        return (
          <div class:list={["schedule-item", highlight && "schedule-item--highlight"]}>
            <div class="schedule-item__date">
              {day.date.slice(5)}
              <br />
              {day.day}
            </div>
            <div>
              <strong>{day.activity}</strong>
              {day.notes && <p class="card__meta">{day.notes}</p>}
            </div>
          </div>
        );
      })
    }
  </div>
</BaseLayout>
