---
import BaseLayout from "../layouts/BaseLayout.astro";
import AudienceIntro from "../components/AudienceIntro.astro";
import PlanStationCard from "../components/PlanStationCard.astro";
import { site, planStations, isCrewStation } from "../lib/plan";
---

<BaseLayout title="Race plan" description="Full aid-station plan from the crew spreadsheet.">
  <div class="container container--wide">
    <AudienceIntro audience="crew" />
    <h1>Race plan</h1>
    <p class="lead">
      Synced from your <a href={site.plan_sheet_url} target="_blank" rel="noopener noreferrer">Google Sheet</a>.
      Edit the sheet, then re-export to update this site.
    </p>

    <div class="filter-bar" role="group" aria-label="Filter stations">
      <button type="button" data-plan-filter="all" aria-pressed="true">All stops</button>
      <button type="button" data-plan-filter="crew" aria-pressed="false">Crew access only</button>
    </div>

    <div class="table-wrap plan-table-desktop">
      <table>
        <thead>
          <tr>
            <th>Station</th>
            <th>Mi</th>
            <th>25h</th>
            <th>28h</th>
            <th>Cutoff</th>
            <th>Who</th>
          </tr>
        </thead>
        <tbody>
          {
            planStations.map((s) => (
              <tr data-plan-row data-crew={isCrewStation(s)}>
                <td>
                  <strong>{s.name}</strong>
                </td>
                <td>{s.mile}</td>
                <td>{s.arrival_25h ?? "—"}</td>
                <td>{s.arrival_28h ?? "—"}</td>
                <td>{s.cutoff ?? "—"}</td>
                <td>{s.who ?? "—"}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="plan-cards-mobile" id="plan-cards">
      {planStations.map((station) => <PlanStationCard station={station} />)}
    </div>
  </div>
</BaseLayout>

<script>
  const rows = document.querySelectorAll("[data-plan-row]");
  const cards = document.querySelectorAll("[data-plan-card]");
  const buttons = document.querySelectorAll("[data-plan-filter]");

  function applyFilter(filter: string) {
    const crewOnly = filter === "crew";
    rows.forEach((row) => {
      const el = row as HTMLElement;
      const show = !crewOnly || el.dataset.crew === "true";
      el.style.display = show ? "" : "none";
    });
    cards.forEach((card) => {
      const el = card as HTMLElement;
      const show = !crewOnly || el.dataset.crew === "true";
      el.style.display = show ? "" : "none";
    });
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.getAttribute("data-plan-filter") ?? "all";
      buttons.forEach((b) => b.setAttribute("aria-pressed", String(b === btn)));
      applyFilter(filter);
    });
  });
</script>
