---
import BaseLayout from "../layouts/BaseLayout.astro";
import AudienceIntro from "../components/AudienceIntro.astro";
import PageNav from "../components/PageNav.astro";
import RememberCallout from "../components/RememberCallout.astro";
import LocationActions from "../components/LocationActions.astro";
import playbooks from "../../data/playbooks.json";
import { crewStops, keyNotes } from "../lib/data";
import { findAidStationForCrew, parseCoordinates } from "../lib/station-links";
import { getEntry } from "astro:content";

const rules = await getEntry("pages", "rules-summary");
const { Content: RulesContent } = await rules.render();
const base = import.meta.env.BASE_URL;

const navItems = [
  { id: "remember", label: "Remember" },
  { id: "playbooks", label: "Playbooks" },
  { id: "stops", label: "Stops" },
  { id: "rules", label: "Rules" },
];

function addressForStop(stop: (typeof crewStops)[number]): string | undefined {
  if (stop.drive_notes.includes("375 Quaking Aspen")) return stop.drive_notes;
  const coords = parseCoordinates(stop.drive_notes);
  if (coords) return `${coords.lat}, ${coords.lng}`;
  return stop.parking;
}
---

<BaseLayout title="Crew" description="Crew playbooks, parking, and stop times for Harvey's Tahoe 200.">
  <div class="container">
    <AudienceIntro audience="crew" />
    <h1>Crew guide</h1>
    <p class="lead">Seven crew-access aids on the Tahoe 200. Playbooks and checklists stick on this phone once you tap them.</p>

    <nav class="section-hub" aria-label="Crew tools">
      <a class="section-hub__link section-hub__link--primary" href={`${base}next/`}>Next stop</a>
      <a class="section-hub__link" href={`${base}board/`}>Race board</a>
      <a class="section-hub__link" href={`${base}aid-stations/`}>Aid stations</a>
    </nav>

    <PageNav items={navItems} />

    <section id="remember">
      <RememberCallout />
    </section>

    <div class="note-box">
      <strong>Vehicle:</strong> {keyNotes.crew_vehicle} We're in an R1S with a Roofnest Sparrow on top — plan for tight lots.
    </div>

    <section id="playbooks">
      <h2>Aid station playbooks</h2>
      <p class="card__meta">Check tasks off as you go — only this phone remembers.</p>
      {
        playbooks.map((book) => (
          <article class="card playbook-card" id={`playbook-${book.crew_stop_n}`}>
            <div class="card__header card__header--static">
              <h3 class="card__title">{book.title}</h3>
              <span class="card__mile">Mile {book.mile}</span>
            </div>
            <ul class="playbook-tasks list-check">
              {book.tasks.map((task) => (
                <li>
                  <label class="playbook-task">
                    <input
                      type="checkbox"
                      data-playbook-task={task.id}
                      data-stop={String(book.crew_stop_n)}
                    />
                    <span>{task.label}</span>
                    {task.category !== "runner" && (
                      <span class="playbook-task__tag">{task.category}</span>
                    )}
                  </label>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </section>

    <h2 id="stops">Stop timeline</h2>
    <div class="crew-timeline">
      {
        crewStops.map((stop) => {
          const aid = findAidStationForCrew(stop.aid_station);
          const coords = parseCoordinates(stop.drive_notes);
          const mapsHref = coords
            ? `https://www.google.com/maps/search/?api=1&query=${coords.lat},${coords.lng}`
            : undefined;
          const address = addressForStop(stop);
          return (
            <article class="card crew-stop" id={`stop-${stop.n}`}>
              <div class="card__header card__header--static">
                <div class="card__header-main">
                  <span class="card__mile">Stop {stop.n} · Mile {stop.mile}</span>
                  <h3 class="card__title">{stop.aid_station}</h3>
                </div>
                <span class="badge badge--crew">Cutoff {stop.cutoff}</span>
              </div>
              <div class="card__body">
                <p class="card__meta">
                  <strong>Planned ETA:</strong> {stop.planned_eta} ·{" "}
                  <a href={`#playbook-${stop.n}`}>Playbook ↑</a>
                </p>
                {
                  aid && (
                    <p class="card__meta">
                      <a href={`${base}aid-stations/#aid-${aid.n}`}>Aid station card →</a>
                    </p>
                  )
                }
                <p>
                  <strong>Parking:</strong> {stop.parking}
                </p>
                <p>
                  <strong>Drive:</strong> {stop.drive_notes}
                </p>
                <LocationActions label={stop.aid_station} address={address} mapsHref={mapsHref} />
              </div>
            </article>
          );
        })
      }
    </div>

    <h2 id="rules">Rules that matter</h2>
    <div class="prose">
      <RulesContent />
    </div>
  </div>
</BaseLayout>

<script>
  import { initPlaybooks } from "../scripts/tahoe-app";
  initPlaybooks();
</script>
