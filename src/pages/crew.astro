---
import BaseLayout from "../layouts/BaseLayout.astro";
import AudienceIntro from "../components/AudienceIntro.astro";
import PageNav from "../components/PageNav.astro";
import RememberCallout from "../components/RememberCallout.astro";
import LocationActions from "../components/LocationActions.astro";
import { crewStops, keyNotes } from "../lib/data";
import { findAidStationForCrew, mapsUrl, parseCoordinates } from "../lib/station-links";
import { getEntry } from "astro:content";

const rules = await getEntry("pages", "rules-summary");
const { Content: RulesContent } = await rules.render();
const base = import.meta.env.BASE_URL;

const navItems = [
  { id: "remember", label: "Remember" },
  { id: "stops", label: "Stops" },
  { id: "rules", label: "Rules" },
];

function addressForStop(stop: (typeof crewStops)[number]): string | undefined {
  if (stop.drive_notes.includes("375 Quaking Aspen")) return stop.drive_notes;
  const coords = parseCoordinates(stop.drive_notes);
  if (coords) return `${coords.lat}, ${coords.lng}`;
  return stop.parking;
}
---

<BaseLayout title="Crew" description="Crew-access stops with parking, ETAs, and restock priorities.">
  <div class="container">
    <AudienceIntro audience="crew" />
    <h1>Crew guide</h1>
    <p class="lead">7 crew-access stops · one vehicle (Rivian R1S fits 20′ × 8.5′ limit)</p>

    <PageNav items={navItems} />

    <section id="remember">
      <RememberCallout />
    </section>

    <div class="note-box">
      <strong>Rivian R1S:</strong> {keyNotes.crew_vehicle} Roofnest Sparrow on top — plan parking at tight lots.
    </div>

    <h2 id="stops">Stop timeline</h2>
    <div class="crew-timeline">
      {
        crewStops.map((stop) => {
          const aid = findAidStationForCrew(stop.aid_station);
          const coords = parseCoordinates(stop.drive_notes);
          const mapsHref = coords ? mapsUrl(coords.lat, coords.lng) : undefined;
          const address = addressForStop(stop);
          return (
            <article class="card crew-stop" id={`stop-${stop.n}`}>
              <div class="card__header card__header--static">
                <div class="card__header-main">
                  <span class="card__mile">Stop {stop.n} · Mile {stop.mile}</span>
                  <h3 class="card__title">{stop.aid_station}</h3>
                </div>
                <span class="badge badge--crew">Cutoff {stop.cutoff}</span>
              </div>
              <div class="card__body">
                <p class="card__meta">
                  <strong>Planned ETA:</strong> {stop.planned_eta}
                </p>
                {
                  aid && (
                    <p class="card__meta">
                      <a href={`${base}aid-stations/#aid-${aid.n}`}>Aid station card →</a>
                    </p>
                  )
                }
                <p>
                  <strong>Parking:</strong> {stop.parking}
                </p>
                <p>
                  <strong>Drive:</strong> {stop.drive_notes}
                </p>
                <LocationActions label={stop.aid_station} address={address} mapsHref={mapsHref} />
                <h4>Restock priorities</h4>
                <ul class="list-check">
                  {stop.restock_priorities.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </article>
          );
        })
      }
    </div>

    <h2 id="rules">Rules that matter</h2>
    <div class="prose">
      <RulesContent />
    </div>
  </div>
</BaseLayout>
