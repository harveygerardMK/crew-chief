---
import BaseLayout from "../layouts/BaseLayout.astro";
import AudienceIntro from "../components/AudienceIntro.astro";
import PageNav from "../components/PageNav.astro";
import PlanStationCard from "../components/PlanStationCard.astro";
import { site, planStations, crewRoster, shotList } from "../lib/plan";

const base = import.meta.env.BASE_URL;
const harveyStations = planStations.filter(
  (s) => s.who?.includes("Crew Van") || s.who?.toLowerCase().includes("harvey"),
);
const navItems = [
  { id: "roster", label: "Roster" },
  { id: "shot-list", label: "Shot list" },
  { id: "your-stops", label: "Your stops" },
];
---

<BaseLayout title="Crew" description="Crew roster, video shot list, and Harvey's aid-station stops.">
  <div class="container">
    <AudienceIntro audience="crew" />
    <h1>Crew & video</h1>
    <p class="lead">
      {site.race} · {site.runner} running · Harvey on crew van / driving ·{" "}
      <a href={site.plan_sheet_url} target="_blank" rel="noopener noreferrer">full plan in Google Sheets</a>
    </p>

    <PageNav items={navItems} />

    <section id="roster">
      <h2>Crew roster</h2>
      <p class="card__meta">
        <strong>{crewRoster.vehicles.crew_van}</strong> vs <strong>{crewRoster.vehicles.fam_van}</strong>
      </p>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Crew van</th>
              <th>Fam van</th>
              <th>Twin Lakes shuttle</th>
            </tr>
          </thead>
          <tbody>
            {
              crewRoster.twin_lakes_shuttles.map((row) => (
                <tr>
                  <td>{row.crew_van ?? "—"}</td>
                  <td>{row.fam_van ?? "—"}</td>
                  <td>{row.location ?? "—"}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section id="shot-list">
      <h2>Video shot list</h2>
      <p class="card__meta">From the plan sheet — check off as you capture each item.</p>
      <ul class="list-check shot-list">
        {shotList.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section id="your-stops">
      <h2>Stops for crew van</h2>
      <p class="card__meta">
        Aid stations where the crew van meets {site.runner}. See the{" "}
        <a href={`${base}plan/`}>full plan</a> for every stop including no-crew sections.
      </p>
      {harveyStations.map((station) => (
        <PlanStationCard station={station} />
      ))}
    </section>

    <p class="card__meta" style="margin-top: 2rem">
      <a href={`${base}plan/`}>← Back to full race plan</a>
    </p>
  </div>
</BaseLayout>
