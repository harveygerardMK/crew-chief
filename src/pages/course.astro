---
import BaseLayout from "../layouts/BaseLayout.astro";
import AudienceIntro from "../components/AudienceIntro.astro";
import CourseProgress from "../components/CourseProgress.astro";
import { race, segments } from "../lib/data";
import { getEntry } from "astro:content";

const overview = await getEntry("pages", "course-overview");
const { Content } = await overview.render();
const mapUrl = race.course_map_url;
---

<BaseLayout title="Course" description="Tahoe 200 course map, narrative, and segment splits.">
  <div class="container container--wide">
    <AudienceIntro audience="runner" />
    <h1>Course</h1>
    <p class="lead">
      {race.distance_miles} mi · {race.elevation_gain_ft.toLocaleString()} ft gain · {race.elevation_loss_ft.toLocaleString()} ft loss
    </p>

    <div class="map-embed">
      <iframe title="CalTopo course map" src={mapUrl} loading="lazy"></iframe>
    </div>
    <p>
      <a class="btn btn--secondary" href={mapUrl} target="_blank" rel="noopener noreferrer">
        Open full map on CalTopo
      </a>
    </p>

    <div class="prose">
      <Content />
    </div>

    <h2>Course profile</h2>
    <CourseProgress />

    <h2>Segments</h2>
    <div class="segment-cards" aria-label="Segments list">
      {
        segments.map((s) => (
          <article class="segment-card">
            <p class="segment-card__name">
              {s.n}. {s.name}
            </p>
            <dl class="segment-card__grid">
              <div>
                <dt>Mi</dt>
                <dd>{s.miles}</dd>
              </div>
              <div>
                <dt>Gain</dt>
                <dd>{s.gain_ft.toLocaleString()} ft</dd>
              </div>
              <div>
                <dt>Loss</dt>
                <dd>{s.loss_ft.toLocaleString()} ft</dd>
              </div>
              <div>
                <dt>Cum. mi</dt>
                <dd>{s.cumulative_miles}</dd>
              </div>
            </dl>
          </article>
        ))
      }
    </div>

    <div class="table-wrap table-wrap--sticky table-wrap--segments-desktop">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Segment</th>
            <th>Mi</th>
            <th>Gain</th>
            <th>Loss</th>
            <th>Cum. mi</th>
            <th>Cum. gain</th>
          </tr>
        </thead>
        <tbody>
          {
            segments.map((s) => (
              <tr>
                <td>{s.n}</td>
                <td>{s.name}</td>
                <td>{s.miles}</td>
                <td>{s.gain_ft.toLocaleString()}</td>
                <td>{s.loss_ft.toLocaleString()}</td>
                <td>{s.cumulative_miles}</td>
                <td>{s.cumulative_gain_ft.toLocaleString()}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
