---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBoardRows, firstHalfPrepNote, planSourceNote, site } from "../lib/tahoe-plan";
import { aidStations, race } from "../lib/data";

const base = import.meta.env.BASE_URL;
const rows = buildBoardRows();
const boardRows = rows.map((r) => ({
  aid_n: r.aid_n,
  crew_access: r.crew_access,
}));
const boardPayloadJson = JSON.stringify({ boardRows, base }).replace(/</g, "\\u003c");
const heroAidStations = aidStations
  .filter(
    (station) =>
      station.crew_access &&
      station.mile > 0 &&
      station.mile < race.distance_miles &&
      station.name !== "Heavenly",
  )
  .map((station) => ({
    ...station,
    short:
      station.name
        .replace(/ Summit$/, "")
        .replace(/\s*\(.*\)/, "")
        .trim(),
  }));
---

<BaseLayout title="Race board" description="Planned vs actual at every Tahoe 200 aid.">
  <section class="elevation-hero elevation-hero--compact" aria-label="Race board hero">
    <div class="container container--wide elevation-hero__copy">
      <div>
        <p class="page-eyebrow">Crew</p>
        <h1>Race board</h1>
        <p class="lead">Check in aid arrivals and compare actual movement against the plan.</p>
      </div>
      <div class="elevation-hero__label">Aid<br />Timeline</div>
    </div>
    <div class="elevation-hero__mountain" aria-hidden="true">
      <svg viewBox="0 0 1200 320" preserveAspectRatio="none">
        <defs>
          <linearGradient id="boardBack" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="var(--mountain-back-top)"></stop>
            <stop offset="100%" stop-color="var(--mountain-back-bottom)"></stop>
          </linearGradient>
          <linearGradient id="boardFront" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="var(--mountain-front-top)"></stop>
            <stop offset="100%" stop-color="var(--mountain-front-bottom)"></stop>
          </linearGradient>
        </defs>
        <path fill="url(#boardBack)" d="M0 320V138L18 98L30 126L42 88L54 160L74 210L110 226L138 116L156 90L174 184L198 244L224 256L248 170L270 176L292 126L316 216L336 148L360 90L378 102L396 60L416 66L438 148L462 112L484 80L510 210L538 190L566 192L592 120L614 72L638 86L666 162L688 58L710 126L736 96L760 52L786 194L812 162L834 48L856 66L886 140L912 208L940 224L962 172L982 158L1004 182L1028 106L1052 82L1074 200L1098 256L1120 208L1140 72L1164 98L1182 158L1200 110V320Z"></path>
        <path fill="url(#boardFront)" d="M0 320V170L24 126L48 164L72 94L98 198L122 228L152 240L178 128L198 100L222 200L246 254L272 264L296 186L316 190L344 138L370 224L390 168L418 114L438 126L464 80L492 88L514 166L542 126L564 92L590 218L616 202L642 204L668 132L694 84L718 100L744 176L768 72L792 136L818 108L842 62L870 200L896 166L920 56L946 74L978 148L1004 212L1030 232L1054 180L1078 166L1102 190L1128 114L1152 88L1176 208L1200 234V320Z"></path>
      </svg>
    </div>
    <ul class="elevation-hero__markers" aria-label="Crew-access aid stations">
      {
        heroAidStations.map((station) => (
          <li
            class="elevation-hero__marker"
            style={`left: ${(station.mile / race.distance_miles) * 100}%`}
          >
            <span class="elevation-hero__marker-dot" aria-hidden="true"></span>
            <span class="elevation-hero__marker-label">
              <span class="elevation-hero__marker-mile">mi {station.mile}</span>
              <span class="elevation-hero__marker-name">{station.short}</span>
            </span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="signal-band signal-band--command" aria-label="Board actions">
    <div class="container container--wide signal-band__inner">
      <p class="priority-action">
        <a class="btn btn--critical" href={`${base}next/`}>Next stop</a>
      </p>
      <p class="board-legend board-legend--compact" id="board-legend">
        <span class="board-status board-status--ahead">Ahead</span>
        <span class="board-status board-status--on-pace">On pace</span>
        <span class="board-status board-status--behind">Behind</span>
        <span class="board-legend__hint">— vs plan at each aid (this phone only)</span>
      </p>
    </div>
  </section>

  <div class="container page-stack zone-content">
    <p class="card__meta card-surface__meta">{planSourceNote()} {firstHalfPrepNote()}</p>

    <div class="table-wrap table-wrap--sticky">
      <table class="board-table" aria-describedby="board-legend">
        <thead>
          <tr>
            <th>#</th>
            <th>Station</th>
            <th>Mile</th>
            <th>Optimistic</th>
            <th>Baseline</th>
            <th>Conservative</th>
            <th>Actual</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody data-board-body>
          {
            rows.map((row) => (
              <tr
                data-board-item
                data-aid={row.aid_n}
                data-opt={row.optimistic_iso}
                data-con={row.conservative_iso}
                class:list={[!row.crew_access && "board-row--no-crew"]}
              >
                <td>{row.aid_n}</td>
                <td>
                  {row.name}
                  {row.crew_access && <span class="badge badge--crew">Crew</span>}
                </td>
                <td>{row.mile}</td>
                <td>{row.optimistic}</td>
                <td>{row.baseline}</td>
                <td>{row.conservative}</td>
                <td data-actual>—</td>
                <td data-status class="board-status board-status--pending">—</td>
                <td>
                  <button type="button" class="btn btn--sm btn--secondary" data-board-checkin={row.aid_n}>
                    Check in
                  </button>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="card__meta">
      Cutoffs shown on <a href={`${base}aid-stations/`}>aid station cards</a>. Plan v{site.plan_version} · Saved on this
      device.
    </p>

    <div class="board-cards-mobile" aria-label="Race board mobile cards">
      {
        rows.map((row) => (
          <article
            class:list={["board-card", !row.crew_access && "board-card--no-crew"]}
            data-board-item
            data-aid={row.aid_n}
            data-opt={row.optimistic_iso}
            data-con={row.conservative_iso}
          >
            <div class="board-card__header">
              <span class="board-card__station-id">{String(row.aid_n).padStart(2, "0")}</span>
              <span data-status class="board-status board-status--pending">Pending</span>
            </div>
            <span class="board-card__barcode" aria-hidden="true"></span>
            <h2 class="board-card__title">{row.name}</h2>
            <p class="card__mile">Aid {row.aid_n} / Mile {row.mile}</p>
            <dl class="board-card__grid">
              <div>
                <dt>Baseline</dt>
                <dd>{row.baseline}</dd>
              </div>
              <div>
                <dt>Actual</dt>
                <dd data-actual>-</dd>
              </div>
              <div>
                <dt>Window</dt>
                <dd>{row.optimistic} / {row.conservative}</dd>
              </div>
            </dl>
            <button type="button" class="btn btn--sm btn--secondary" data-board-checkin={row.aid_n}>
              Check in
            </button>
          </article>
        ))
      }
    </div>
  </div>
</BaseLayout>

<script id="board-payload" type="application/json" set:html={boardPayloadJson}></script>

<script>
  import { initRaceBoard } from "../scripts/tahoe-app";

  const payload = JSON.parse(document.getElementById("board-payload")?.textContent ?? "{}");
  initRaceBoard(payload.boardRows ?? [], payload.base ?? "/");
</script>
