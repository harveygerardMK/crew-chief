---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBoardRows, firstHalfPrepNote, planSourceNote, site } from "../lib/tahoe-plan";

const base = import.meta.env.BASE_URL;
const rows = buildBoardRows();
const boardRows = rows.map((r) => ({
  aid_n: r.aid_n,
  crew_access: r.crew_access,
}));
const boardPayloadJson = JSON.stringify({ boardRows, base }).replace(/</g, "\\u003c");
---

<BaseLayout title="Race board" description="Planned vs actual at every Tahoe 200 aid.">
  <section class="elevation-hero elevation-hero--compact" aria-label="Race board hero">
    <div class="container container--wide elevation-hero__copy">
      <div>
        <p class="page-eyebrow">Crew</p>
        <h1>Race board</h1>
        <p class="lead">Check in aid arrivals and compare actual movement against the plan.</p>
      </div>
      <div class="elevation-hero__label">Aid<br />Timeline</div>
    </div>
    <div class="elevation-hero__mountain" aria-hidden="true">
      <svg viewBox="0 0 1200 320" preserveAspectRatio="none">
        <defs>
          <linearGradient id="boardBack" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="rgba(30,72,143,.56)"></stop>
            <stop offset="100%" stop-color="rgba(30,72,143,.3)"></stop>
          </linearGradient>
          <linearGradient id="boardFront" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="rgba(0,128,76,.82)"></stop>
            <stop offset="100%" stop-color="rgba(0,128,76,.62)"></stop>
          </linearGradient>
        </defs>
        <path fill="url(#boardBack)" d="M0 320V168L52 124L104 200L160 116L210 218L264 130L318 214L372 116L430 220L486 136L542 226L598 132L654 222L708 124L760 206L812 138L870 228L922 146L980 214L1032 120L1094 206L1152 138L1200 184V320Z"></path>
        <path fill="url(#boardFront)" d="M0 320V196L40 160L88 222L140 148L186 238L242 156L296 228L352 154L410 236L468 164L526 244L582 156L642 236L698 150L748 220L804 160L860 244L916 174L970 228L1024 150L1080 224L1138 166L1200 212V320Z"></path>
      </svg>
    </div>
  </section>

  <div class="container page-stack">
    <p class="card__meta">{planSourceNote()} {firstHalfPrepNote()}</p>
    <p class="priority-action">
      <a class="btn btn--primary" href={`${base}next/`}>Next stop</a>
    </p>

    <p class="board-legend" id="board-legend">
      <span class="board-status board-status--ahead">Ahead</span>
      <span class="board-status board-status--on-pace">On pace</span>
      <span class="board-status board-status--behind">Behind</span>
      <span class="board-legend__hint">— vs plan at each aid (this phone only)</span>
    </p>

    <div class="table-wrap table-wrap--sticky">
      <table class="board-table" aria-describedby="board-legend">
        <thead>
          <tr>
            <th>#</th>
            <th>Station</th>
            <th>Mile</th>
            <th>Optimistic</th>
            <th>Baseline</th>
            <th>Conservative</th>
            <th>Actual</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody data-board-body>
          {
            rows.map((row) => (
              <tr
                data-board-item
                data-aid={row.aid_n}
                data-opt={row.optimistic_iso}
                data-con={row.conservative_iso}
                class:list={[!row.crew_access && "board-row--no-crew"]}
              >
                <td>{row.aid_n}</td>
                <td>
                  {row.name}
                  {row.crew_access && <span class="badge badge--crew">Crew</span>}
                </td>
                <td>{row.mile}</td>
                <td>{row.optimistic}</td>
                <td>{row.baseline}</td>
                <td>{row.conservative}</td>
                <td data-actual>—</td>
                <td data-status class="board-status board-status--pending">—</td>
                <td>
                  <button type="button" class="btn btn--sm btn--secondary" data-board-checkin={row.aid_n}>
                    Check in
                  </button>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="card__meta">
      Cutoffs shown on <a href={`${base}aid-stations/`}>aid station cards</a>. Plan v{site.plan_version} · Saved on this
      device.
    </p>

    <div class="board-cards-mobile" aria-label="Race board mobile cards">
      {
        rows.map((row) => (
          <article
            class:list={["board-card", !row.crew_access && "board-card--no-crew"]}
            data-board-item
            data-aid={row.aid_n}
            data-opt={row.optimistic_iso}
            data-con={row.conservative_iso}
          >
            <div class="board-card__header">
              <span class="board-card__station-id">{String(row.aid_n).padStart(2, "0")}</span>
              <span data-status class="board-status board-status--pending">Pending</span>
            </div>
            <span class="board-card__barcode" aria-hidden="true"></span>
            <h2 class="board-card__title">{row.name}</h2>
            <p class="card__mile">Aid {row.aid_n} / Mile {row.mile}</p>
            <dl class="board-card__grid">
              <div>
                <dt>Baseline</dt>
                <dd>{row.baseline}</dd>
              </div>
              <div>
                <dt>Actual</dt>
                <dd data-actual>-</dd>
              </div>
              <div>
                <dt>Window</dt>
                <dd>{row.optimistic} / {row.conservative}</dd>
              </div>
            </dl>
            <button type="button" class="btn btn--sm btn--secondary" data-board-checkin={row.aid_n}>
              Check in
            </button>
          </article>
        ))
      }
    </div>
  </div>
</BaseLayout>

<script id="board-payload" type="application/json" set:html={boardPayloadJson}></script>

<script>
  import { initRaceBoard } from "../scripts/tahoe-app";

  const payload = JSON.parse(document.getElementById("board-payload")?.textContent ?? "{}");
  initRaceBoard(payload.boardRows ?? [], payload.base ?? "/");
</script>
