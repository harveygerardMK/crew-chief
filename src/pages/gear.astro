---
import BaseLayout from "../layouts/BaseLayout.astro";
import AudienceIntro from "../components/AudienceIntro.astro";
import PageNav from "../components/PageNav.astro";
import { gear, racePrep } from "../lib/data";

const navItems = [
  { id: "prep", label: "Prep & safety" },
  { id: "mandatory-clothing", label: "Clothing" },
  { id: "mandatory-equipment", label: "Equipment" },
  { id: "mandatory-food", label: "Food" },
  { id: "foot-care", label: "Foot care" },
  { id: "recommended", label: "Recommended" },
  { id: "drop-bags", label: "Drop bags" },
];
---

<BaseLayout title="Gear" description="Mandatory and recommended gear for Harvey's Tahoe 200.">
  <div class="container page-stack">
    <AudienceIntro audience="runner" />
    <h1>Gear</h1>
    <p class="lead">
      What I have to carry, what the medical director wants us thinking about (May 2026), and what's in each drop bag.
    </p>

    <p class="card__meta">
      <strong>Action:</strong>
      <a href={racePrep.medical_form_url} target="_blank" rel="noopener noreferrer">Complete mandatory Medical Form</a>
      ·
      <a href={racePrep.all_emails_url} target="_blank" rel="noopener noreferrer">Tahoe 2026 all emails</a>
    </p>

    <PageNav items={navItems} />

    <section class="card" id="prep" aria-labelledby="prep-heading">
      <h2 id="prep-heading">Prep & safety</h2>
      <p class="card__meta">{racePrep.source}</p>
      <p>
        Medical leads: {racePrep.medical_leads.join(", ")}. Sleep target: {racePrep.sleep_guidance.start_by}.{" "}
        {racePrep.sleep_guidance.nap_benefit}
      </p>
      {
        racePrep.sections.map((section) => (
          <div class="prep-block">
            <h3>{section.title}</h3>
            <ul class="list-check">
              {section.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </section>

    <h2 id="mandatory-clothing">Mandatory clothing</h2>
    <ul class="list-check">
      {
        gear.mandatory_clothing.map((item) => (
          <li>
            <strong>{item.item}</strong> — {item.spec}
            {item.notes && <em> ({item.notes})</em>}
          </li>
        ))
      }
    </ul>

    <h2 id="mandatory-equipment">Mandatory equipment</h2>
    <ul class="list-check">
      {
        gear.mandatory_equipment.map((item) => (
          <li>
            <strong>{item.item}</strong> — {item.spec}
            {item.notes && <em> ({item.notes})</em>}
          </li>
        ))
      }
    </ul>

    <h2 id="mandatory-food">Mandatory food & fluids</h2>
    <ul class="list-check">
      {
        gear.mandatory_food.map((item) => (
          <li>
            <strong>{item.item}</strong> — {item.spec}
            {item.notes && <em> ({item.notes})</em>}
          </li>
        ))
      }
    </ul>

    <h2 id="foot-care">Foot care — on person</h2>
    <p class="card__meta">On my person; the big kit is in drop bags and with crew below.</p>
    <ul class="list-check">
      {
        gear.on_person_foot_care.map((item) => (
          <li>
            <strong>{item.item}</strong>
            {item.notes && <em> — {item.notes}</em>}
          </li>
        ))
      }
    </ul>
    <h3>Drop bags & crew — foot care stash</h3>
    <ul class="list-check">
      {gear.drop_bag_foot_care.map((item) => <li>{item}</li>)}
    </ul>

    <h2 id="recommended">Recommended carry</h2>
    <ul class="list-check">
      {gear.recommended_carry.map((item) => <li>{item.item}{item.notes ? ` — ${item.notes}` : ""}</li>)}
    </ul>

    <h2 id="drop-bags">Drop bag strategy</h2>
    {
      gear.drop_bag_strategy.map((bag) => (
        <article class="card">
          <div class="card__header card__header--static">
            <div>
              <h3 class="card__title">{bag.station}</h3>
              <span class="badge">{bag.tier}</span>
            </div>
          </div>
          <div class="card__body">
            <p>{bag.contents}</p>
          </div>
        </article>
      ))
    }
  </div>
</BaseLayout>
