---
import BaseLayout from "../layouts/BaseLayout.astro";
import AudienceIntro from "../components/AudienceIntro.astro";
import PageNav from "../components/PageNav.astro";
import { gear } from "../lib/data";

const navItems = [
  { id: "mandatory-clothing", label: "Clothing" },
  { id: "mandatory-equipment", label: "Equipment" },
  { id: "mandatory-food", label: "Food" },
  { id: "recommended", label: "Recommended" },
  { id: "drop-bags", label: "Drop bags" },
];
---

<BaseLayout title="Gear" description="Harvey Schaefer's mandatory and recommended Tahoe 200 gear.">
  <div class="container">
    <AudienceIntro audience="runner" />
    <h1>Harvey's gear</h1>
    <p class="lead">Tahoe 200 mandatory kit, recommended carry, and drop-bag strategy</p>

    <PageNav items={navItems} />

    <h2 id="mandatory-clothing">Mandatory clothing</h2>
    <ul class="list-check">
      {
        gear.mandatory_clothing.map((item) => (
          <li>
            <strong>{item.item}</strong> — {item.spec}
            {item.notes && <em> ({item.notes})</em>}
          </li>
        ))
      }
    </ul>

    <h2 id="mandatory-equipment">Mandatory equipment</h2>
    <ul class="list-check">
      {
        gear.mandatory_equipment.map((item) => (
          <li>
            <strong>{item.item}</strong> — {item.spec}
            {item.notes && <em> ({item.notes})</em>}
          </li>
        ))
      }
    </ul>

    <h2 id="mandatory-food">Mandatory food</h2>
    <ul class="list-check">
      {
        gear.mandatory_food.map((item) => (
          <li>
            <strong>{item.item}</strong> — {item.spec}
            {item.notes && <em> ({item.notes})</em>}
          </li>
        ))
      }
    </ul>

    <h2 id="recommended">Recommended carry</h2>
    <ul class="list-check">
      {gear.recommended_carry.map((item) => <li>{item.item}{item.notes ? ` — ${item.notes}` : ""}</li>)}
    </ul>

    <h2 id="drop-bags">Drop bag strategy</h2>
    {
      gear.drop_bag_strategy.map((bag) => (
        <article class="card">
          <div class="card__header card__header--static">
            <div>
              <h3 class="card__title">{bag.station}</h3>
              <span class="badge">{bag.tier}</span>
            </div>
          </div>
          <div class="card__body">
            <p>{bag.contents}</p>
          </div>
        </article>
      ))
    }
  </div>
</BaseLayout>
