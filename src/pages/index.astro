---
import BaseLayout from "../layouts/BaseLayout.astro";
import StatusBlock from "../components/StatusBlock.astro";
import AudiencePaths from "../components/AudiencePaths.astro";
import site from "../../data/site.json";
import { race } from "../lib/data";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <div class="home-hero">
    <div class="container">
      <StatusBlock />
      <p class="page-eyebrow">{site.race} · {site.year}</p>
      <h1>{site.name}</h1>
      <p class="lead">
        {site.runner} is running {site.distance_miles} miles around Lake Tahoe, June 12–16, 2026. Crew command
        center, playbooks, and family follow-along — Tahoe 200 only.
      </p>
      <p>
        <a class="btn btn--primary" href={`${base}next/`}>
          Next crew stop
        </a>
        <a class="btn btn--secondary" href={`${base}board/`}>
          Race board
        </a>
      </p>
    </div>
  </div>
  <div class="container">
    <AudiencePaths />
    <p class="card__meta" style="margin-top: 1.5rem">
      {site.tagline} Plan v{site.plan_version}. Offline at trailheads — add to home screen from your browser menu.
    </p>
    <p class="card__meta">
      Official Tahoe 200 tracking:{" "}
      <a href={race.live_tracking_url_placeholder} target="_blank" rel="noopener noreferrer">
        destinationtrailrun.com/tahoe
      </a>
    </p>
  </div>
</BaseLayout>
