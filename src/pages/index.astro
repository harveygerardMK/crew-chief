---
import BaseLayout from "../layouts/BaseLayout.astro";
import StatusBlock from "../components/StatusBlock.astro";
import LiveRaceUpdates from "../components/LiveRaceUpdates.astro";
import CrewOps from "../components/CrewOps.astro";
import RaceDataBand from "../components/RaceDataBand.astro";
import site from "../../data/site.json";
import { race } from "../lib/data";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <div class="home-mission">
    <div class="container container--dashboard">
      <div class="home-mission__board">
        <RaceDataBand />
        <div class="home-mission__grid">
          <section class="home-mission__intro">
            <StatusBlock />
            <p class="page-eyebrow">Crew Chief / {site.race} / {site.year}</p>
            <h1>Make the next crew call.</h1>
            <p class="lead">
              Live course intel, crew timing, and trail logistics for Harvey's {site.distance_miles}-mile loop around Lake Tahoe.
            </p>
            <p class="home-hero__actions">
              <a class="btn btn--primary" href={`${base}next/`}>
                Next stop
              </a>
              <a class="btn btn--secondary" href={`${base}board/`}>
                Race board
              </a>
              <a class="btn btn--secondary" href={`${base}crew/`}>
                Crew guide
              </a>
            </p>
          </section>
          <div class="home-hero__aside home-entry-card" aria-hidden="true">
            <span class="home-entry-card__label">Entrance / group</span>
            <span class="home-entry-card__barcode"></span>
            <span class="home-entry-card__group">[ H ]</span>
            <span class="home-entry-card__route-label">Tahoe loop signal</span>
            <svg class="home-entry-card__route" viewBox="0 0 220 110" role="img" aria-label="Abstract Tahoe route">
              <defs>
                <linearGradient id="routeStroke" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#657492"></stop>
                  <stop offset="55%" stop-color="#ff6031"></stop>
                  <stop offset="100%" stop-color="#c9ff00"></stop>
                </linearGradient>
              </defs>
              <path
                d="M15 70 C32 24, 72 20, 100 34 C127 46, 160 43, 188 18 C206 38, 198 67, 172 84 C139 105, 80 106, 43 90 C26 82, 17 77, 15 70 Z"
                fill="none"
                stroke="url(#routeStroke)"
                stroke-width="6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <circle cx="21" cy="68" r="4" fill="#ff6031"></circle>
              <circle cx="188" cy="18" r="4" fill="#c9ff00"></circle>
            </svg>
            <span class="home-hero__mile tabular">{race.distance_miles}</span>
            <span class="home-hero__mile-unit">mi / full loop</span>
          </div>
          <LiveRaceUpdates />
          <CrewOps />
        </div>
        <p class="card__meta site-meta site-meta--compact">
          Family: <a href={`${base}follow/`}>Follow along</a> /{" "}
          Tracker:{" "}
          <a href={race.live_tracking_url_placeholder} target="_blank" rel="noopener noreferrer">
            destinationtrailrun.com/tahoe
          </a>{" "}
          / Plan v{site.plan_version} / Add this site to your home screen for spotty trailhead service.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
