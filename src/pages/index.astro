---
import BaseLayout from "../layouts/BaseLayout.astro";
import StatusBlock from "../components/StatusBlock.astro";
import AudiencePaths from "../components/AudiencePaths.astro";
import site from "../../data/site.json";
import { race } from "../lib/data";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <div class="home-hero">
    <div class="container">
      <StatusBlock />
      <p class="page-eyebrow">{site.race}</p>
      <h1>{site.name}</h1>
      <p class="lead">
        Crew plan for {site.runner} — {site.distance_miles} miles around Lake Tahoe, June 12–16, 2026.
      </p>
      <p>
        <a class="btn btn--primary" href={`${base}next/`}>
          Next stop
        </a>
        <a class="btn btn--secondary" href={`${base}board/`}>
          Race board
        </a>
      </p>
    </div>
  </div>
  <div class="container">
    <AudiencePaths />
    <p class="card__meta" style="margin-top: 1.5rem">
      Plan v{site.plan_version} · Course, gear, pacers, and schedule in the nav · Offline at trailheads (install from
      browser menu).
    </p>
    <p class="card__meta">
      Live tracking:{" "}
      <a href={race.live_tracking_url_placeholder} target="_blank" rel="noopener noreferrer">
        destinationtrailrun.com/tahoe
      </a>
    </p>
  </div>
</BaseLayout>
