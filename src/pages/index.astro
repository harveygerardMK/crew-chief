---
import BaseLayout from "../layouts/BaseLayout.astro";
import StatusBlock from "../components/StatusBlock.astro";
import StatStrip from "../components/StatStrip.astro";
import AudiencePaths from "../components/AudiencePaths.astro";
import ContourBackdrop from "../components/ContourBackdrop.astro";
import site from "../../data/site.json";
import { race } from "../lib/data";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <div class="home-hero">
    <ContourBackdrop />
    <div class="container home-hero__inner">
      <div class="home-hero__main">
        <StatusBlock />
        <p class="page-eyebrow">{site.race} · {site.year}</p>
        <h1>{site.name}</h1>
        <p class="lead">
          {site.runner} is running {site.distance_miles} miles around Lake Tahoe, June 12–16, 2026. Crew command
          center, playbooks, and family follow-along.
        </p>
        <p class="home-hero__actions">
          <a class="btn btn--primary" href={`${base}next/`}>
            Next crew stop
          </a>
          <a class="btn btn--secondary" href={`${base}board/`}>
            Race board
          </a>
        </p>
      </div>
      <div class="home-hero__aside" aria-hidden="true">
        <span class="home-hero__mile tabular">{race.distance_miles}</span>
        <span class="home-hero__mile-unit">mi</span>
      </div>
    </div>
  </div>
  <div class="container">
    <StatStrip />
    <hr class="section-rule section-rule--contour" />
    <AudiencePaths />
    <p class="card__meta site-meta">
      {site.tagline} Plan v{site.plan_version}. Offline at trailheads — add to home screen from your browser menu.
    </p>
    <p class="card__meta site-meta">
      Official Tahoe 200 tracking:{" "}
      <a href={race.live_tracking_url_placeholder} target="_blank" rel="noopener noreferrer">
        destinationtrailrun.com/tahoe
      </a>
    </p>
  </div>
</BaseLayout>
