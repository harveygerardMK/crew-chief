---
import BaseLayout from "../layouts/BaseLayout.astro";
import StatusBlock from "../components/StatusBlock.astro";
import LiveRaceUpdates from "../components/LiveRaceUpdates.astro";
import CrewOps from "../components/CrewOps.astro";
import RaceDataBand from "../components/RaceDataBand.astro";
import site from "../../data/site.json";
import { aidStations, race } from "../lib/data";

const base = import.meta.env.BASE_URL;
const heroAidStations = aidStations
  .filter((station) => station.crew_access && station.mile > 0 && station.mile < race.distance_miles)
  .map((station) => ({
    ...station,
    x: (station.mile / race.distance_miles) * 1200,
  }));
---

<BaseLayout title="Home">
  <section class="elevation-hero" aria-label="Tahoe elevation hero">
    <div class="container container--wide elevation-hero__copy">
      <div>
        <h1>Tahoe 200 alpine race logistics</h1>
        <p class="home-hero__actions">
          <a class="btn btn--primary" href={`${base}next/`}>
            Next stop now
          </a>
          <a class="btn btn--secondary" href={`${base}board/`}>
            Race board
          </a>
          <a class="btn btn--secondary" href={`${base}crew/`}>
            Crew guide
          </a>
        </p>
      </div>
    </div>
    <div class="elevation-hero__mountain" aria-hidden="true">
      <svg viewBox="0 0 1200 320">
        <defs>
          <linearGradient id="homeBack" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="rgba(30,72,143,.56)"></stop>
            <stop offset="100%" stop-color="rgba(30,72,143,.3)"></stop>
          </linearGradient>
          <linearGradient id="homeFront" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="rgba(0,128,76,.82)"></stop>
            <stop offset="100%" stop-color="rgba(0,128,76,.62)"></stop>
          </linearGradient>
        </defs>
        <path fill="url(#homeBack)" d="M0 320V138L18 98L30 126L42 88L54 160L74 210L110 226L138 116L156 90L174 184L198 244L224 256L248 170L270 176L292 126L316 216L336 148L360 90L378 102L396 60L416 66L438 148L462 112L484 80L510 210L538 190L566 192L592 120L614 72L638 86L666 162L688 58L710 126L736 96L760 52L786 194L812 162L834 48L856 66L886 140L912 208L940 224L962 172L982 158L1004 182L1028 106L1052 82L1074 200L1098 256L1120 208L1140 72L1164 98L1182 158L1200 110V320Z"></path>
        <path fill="url(#homeFront)" d="M0 320V170L24 126L48 164L72 94L98 198L122 228L152 240L178 128L198 100L222 200L246 254L272 264L296 186L316 190L344 138L370 224L390 168L418 114L438 126L464 80L492 88L514 166L542 126L564 92L590 218L616 202L642 204L668 132L694 84L718 100L744 176L768 72L792 136L818 108L842 62L870 200L896 166L920 56L946 74L978 148L1004 212L1030 232L1054 180L1078 166L1102 190L1128 114L1152 88L1176 208L1200 234V320Z"></path>
        <g class="elevation-hero__markers">
          {
            heroAidStations.map((station) => (
              <g transform={`translate(${station.x}, 118)`}>
                <line x1="0" y1="0" x2="0" y2="16"></line>
                <circle cx="0" cy="0" r="3"></circle>
                <text x="0" y="-8">{station.name}</text>
              </g>
            ))
          }
        </g>
      </svg>
    </div>
  </section>

  <div class="page-meta-band container container--wide">
    <div>Distance {race.distance_miles} mi</div>
    <div>Pace baseline</div>
    <div>Aid status on track</div>
    <div>Cutoff 100h</div>
    <div>Plan v{site.plan_version}</div>
  </div>

  <div class="page-priority-row container container--wide">
    <article class="page-priority-card page-priority-card--critical">
      <p class="page-priority-card__k">Critical action</p>
      <p class="page-priority-card__v">Depart for spooner in 34 min</p>
    </article>
    <article class="page-priority-card">
      <p class="page-priority-card__k">Current segment</p>
      <p class="page-priority-card__v">Heavenly to spooner</p>
    </article>
    <article class="page-priority-card">
      <p class="page-priority-card__k">Crew prep</p>
      <p class="page-priority-card__v">Fuel + socks + headlamp</p>
    </article>
  </div>

  <div class="container container--wide page-stack">
    <StatusBlock />
    <RaceDataBand />
    <div class="home-mission__grid">
      <LiveRaceUpdates />
      <CrewOps />
    </div>
    <p class="card__meta site-meta site-meta--compact">
      Family: <a href={`${base}follow/`}>Follow along</a> / Tracker:{" "}
      <a href={race.live_tracking_url_placeholder} target="_blank" rel="noopener noreferrer">
        destinationtrailrun.com/tahoe
      </a>{" "}
      / Plan v{site.plan_version} / Add this site to your home screen for spotty trailhead service.
    </p>
  </div>
</BaseLayout>
