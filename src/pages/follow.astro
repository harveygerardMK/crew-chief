---
import BaseLayout from "../layouts/BaseLayout.astro";
import AudienceIntro from "../components/AudienceIntro.astro";
import StatusBlock from "../components/StatusBlock.astro";
import familyStops from "../../data/family-stops.json";
import { race, status } from "../lib/data";
import { formatPlanTimeShort, plannedArrivalDate } from "../lib/tahoe-plan";
import { getEntry } from "astro:content";

const about = await getEntry("pages", "about-the-race");
const { Content: AboutContent } = await about.render();
const trackingUrl = status.live_tracking_url ?? race.live_tracking_url_placeholder;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Follow" description="Follow Harvey at the Tahoe 200 — where to watch, rough ETAs, tracker tips.">
  <div class="container page-stack">
    <AudienceIntro audience="follow" />
    <h1>Follow along</h1>
    <p class="lead">Where to watch, when to expect Harvey, and how to read the tracker.</p>

    <StatusBlock />

    <div class="status-block__actions">
      <a class="btn btn--primary" href={trackingUrl} target="_blank" rel="noopener noreferrer">
        Live tracking
      </a>
      <a class="btn btn--secondary" href={`${base}agent/`}>
        Ask Harvey (chat)
      </a>
    </div>

    <section class="family-see" aria-labelledby="family-stops-heading">
      <h2 id="family-stops-heading">Good places to see me</h2>
      <p class="card__meta">Crew aids where spectating is easier. Times are the baseline plan — I might be early or late.</p>
      <div class="family-see__grid">
        {
          familyStops.map((stop) => {
            const eta = formatPlanTimeShort(plannedArrivalDate(stop.mile, "baseline"));
            return (
              <article class="card family-card">
                <h3>{stop.name}</h3>
                <p class="card__meta">
                  Mile {stop.mile} · Plan ~{eta} · Cutoff {stop.cutoff}
                </p>
                <p>{stop.how_to_see}</p>
                <p class="card__meta">{stop.parking_note}</p>
              </article>
            );
          })
        }
      </div>
    </section>

    <details class="more-panel">
      <summary>Tracker notes and race background</summary>
      <div class="note-box">
        <strong>Don't panic if the dot disappears.</strong> Gaps on the tracker are normal in the backcountry. Crew has the
        full plan. I can sleep up to 6 hours at a sleep station — a long pause usually just means I'm in a tent, not that
        something's wrong.
      </div>

      <div class="prose">
        <AboutContent />
      </div>

      <h2>Tracker signals</h2>
      <ul class="list-check">
        <li>
          <strong>Moving / updating:</strong> I'm on course and the SPOT is pinging.
        </li>
        <li>
          <strong>Stopped at an aid:</strong> Normal — food, sleep, feet, bathroom.
        </li>
        <li>
          <strong>No updates for a while:</strong> Happens in the backcountry. Short gaps are normal.
        </li>
      </ul>

      <h2>Send a short note</h2>
      <p>
        Cell service is spotty. Best path is crew at a crew aid (Heavenly, Sierra at Tahoe, Loon Lake, Tahoe City,
        Brockway, Village Green, Finish). Ask them to pass something short — I'll see it when I roll in.
      </p>

      <h2>Important links</h2>
      <ul class="quick-links">
        <li>
          <a href={race.official_url} target="_blank" rel="noopener noreferrer">Official race site</a>
        </li>
        <li>
          <a href={race.course_map_url} target="_blank" rel="noopener noreferrer">Course map (CalTopo)</a>
        </li>
        <li>
          <a href={`${base}board/`}>Race board</a> (more detail if you want it)
        </li>
      </ul>
    </details>
  </div>
</BaseLayout>
