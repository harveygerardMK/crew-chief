---
import BaseLayout from "../layouts/BaseLayout.astro";
import AudienceIntro from "../components/AudienceIntro.astro";
import StatusBlock from "../components/StatusBlock.astro";
import familyStops from "../../data/family-stops.json";
import { race, status } from "../lib/data";
import { formatPlanTimeShort, plannedArrivalDate } from "../lib/tahoe-plan";
import { getEntry } from "astro:content";

const about = await getEntry("pages", "about-the-race");
const { Content: AboutContent } = await about.render();
const trackingUrl = status.live_tracking_url ?? race.live_tracking_url_placeholder;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Follow" description="Follow Harvey Schaefer at the Tahoe 200 Endurance Run — family stops, ETAs, tracker.">
  <div class="container">
    <AudienceIntro audience="follow" />
    <h1>Follow Harvey at Tahoe 200</h1>
    <p class="lead">Where to see him on course, when to expect him, and how to read the live tracker</p>

    <StatusBlock />

    <p>
      <a class="btn btn--primary" href={trackingUrl} target="_blank" rel="noopener noreferrer">
        Live tracking
      </a>
    </p>

    <section class="family-see" aria-labelledby="family-stops-heading">
      <h2 id="family-stops-heading">Best places to see Harvey</h2>
      <p class="card__meta">Crew-access stops with easier spectating. Times are baseline plan — he may be earlier or later.</p>
      <div class="family-see__grid">
        {
          familyStops.map((stop) => {
            const eta = formatPlanTimeShort(plannedArrivalDate(stop.mile, "baseline"));
            return (
              <article class="card family-card">
                <h3>{stop.name}</h3>
                <p class="card__meta">
                  Mile {stop.mile} · Plan ~{eta} · Cutoff {stop.cutoff}
                </p>
                <p>{stop.how_to_see}</p>
                <p class="card__meta">{stop.parking_note}</p>
              </article>
            );
          })
        }
      </div>
    </section>

    <div class="note-box">
      <strong>Reassurance:</strong> Gaps on the map are normal in the backcountry. Crew has the full plan. Sleep stops
      allow up to 6 hours — a long pause does not mean something is wrong.
    </div>

    <div class="prose">
      <AboutContent />
    </div>

    <h2>Reading the tracker</h2>
    <ul class="list-check">
      <li>
        <strong>Green / moving:</strong> Harvey is on course and the SPOT is updating.
      </li>
      <li>
        <strong>Stopped at an aid station:</strong> Normal — eating, sleeping, or foot care.
      </li>
      <li>
        <strong>Gaps in updates:</strong> Common in backcountry. Don’t panic on short gaps.
      </li>
    </ul>

    <h2>Sending a message</h2>
    <p>
      Cell service is limited. The best way to reach Harvey is through crew at a crew-access aid (Heavenly, Sierra at
      Tahoe, Loon Lake, Tahoe City, Brockway, Village Green, Finish). Ask crew to pass a short encouraging note.
    </p>

    <h2>Important links</h2>
    <ul class="quick-links">
      <li>
        <a href={race.official_url} target="_blank" rel="noopener noreferrer">Official race site</a>
      </li>
      <li>
        <a href={race.course_map_url} target="_blank" rel="noopener noreferrer">Course map (CalTopo)</a>
      </li>
      <li>
        <a href={`${base}board/`}>Crew race board</a> (for family who want more detail)
      </li>
    </ul>
  </div>
</BaseLayout>
