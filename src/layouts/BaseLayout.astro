---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

import site from "../../data/site.json";
import SiteNav from "../components/SiteNav.astro";

const { title, description = `${site.runner}'s Tahoe 200 ${site.year} — race plan, crew tools, and follow-along.` } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonicalPath =
  Astro.url.pathname.replace(basePath, "").replace(/\/$/, "") || "/";
const pageTitle = title === "Home" ? site.name : `${title} · ${site.name}`;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#00d4a4" />
    <title>{pageTitle}</title>
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-logo" href={base}>Harvey · Tahoe 200</a>
        <SiteNav canonicalPath={canonicalPath} base={base} />
        <button type="button" id="trailhead-toggle" class="btn btn--sm btn--secondary trailhead-toggle">
          Trailhead mode
        </button>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>
          {site.runner} running {site.race} · {site.year} · Plan v{site.plan_version}
        </p>
      </div>
    </footer>
  </body>
</html>

<script define:vars={{ base }}>
  import { initTrailheadMode, registerServiceWorker } from "../scripts/tahoe-app";
  initTrailheadMode();
  registerServiceWorker(base);
</script>
