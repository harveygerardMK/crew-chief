---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Tahoe 200 2026 — race plan, crew logistics, and live follow-along." } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonicalPath =
  Astro.url.pathname.replace(basePath, "").replace(/\/$/, "") || "/";
const pageTitle = title === "Home" ? "Tahoe 200 2026" : `${title} · Tahoe 200 2026`;

const nav = [
  { href: "/", label: "Home" },
  { href: "/course/", label: "Course" },
  { href: "/aid-stations/", label: "Aid" },
  { href: "/crew/", label: "Crew" },
  { href: "/pacers/", label: "Pacers" },
  { href: "/gear/", label: "Gear" },
  { href: "/schedule/", label: "Schedule" },
  { href: "/follow/", label: "Follow" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-logo" href={import.meta.env.BASE_URL}>Tahoe 200</a>
        <nav class="site-nav" aria-label="Main">
          {
            nav.map((item) => {
              const href = `${import.meta.env.BASE_URL}${item.href === "/" ? "" : item.href.slice(1)}`;
              const isCurrent =
                item.href === "/"
                  ? canonicalPath === "/" || canonicalPath === ""
                  : canonicalPath.startsWith(item.href.replace(/\/$/, ""));
              return (
                <a href={href} aria-current={isCurrent ? "page" : undefined}>
                  {item.label}
                </a>
              );
            })
          }
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>Harvey Schaefer · Tahoe 200 Endurance Run · June 2026</p>
      </div>
    </footer>
  </body>
</html>
